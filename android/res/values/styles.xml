<?xml version="1.0" encoding="utf-8"?>
<!-- Tema dell'unica Activity. Fullscreen "vero": non basta nascondere le barre di
     sistema (quello lo fanno i flag in android_jni.zig), bisogna anche che la FINESTRA si
     estenda dove le barre stavano — altrimenti resta la banda nera che il frame
     [0,91][1080,2400] denunciava. Le due voci translucent fanno esattamente questo. -->
<resources>
    <style name="Zuer.Fullscreen" parent="@android:style/Theme.NoTitleBar.Fullscreen">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
