<?xml version="1.0" encoding="utf-8"?>
<!-- Da Android 9 (API 28, ma l'attributo esiste dalla 27) una finestra viene laid-out
     SOTTO il ritaglio del display se non chiede il contrario: è la vera ragione per cui la
     nostra partiva a y=91 anche con la status bar già nascosta. `shortEdges` la lascia
     salire fino al bordo, foro della fotocamera compreso; il contenuto della UI si tiene
     alla larga da lì con la fascia sicura di `safeTop()`. -->
<resources>
    <style name="Zuer.Fullscreen" parent="@android:style/Theme.NoTitleBar.Fullscreen">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
